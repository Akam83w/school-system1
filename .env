# ============================================================================
# SCHOOL MANAGEMENT SYSTEM — ENVIRONMENT CONFIGURATION
# ============================================================================
#
# This file documents ALL environment variables required for both frontend
# and backend to operate as a unified system.
#
# COPY THIS FILE TO .env AND FILL IN YOUR DEPLOYMENT-SPECIFIC VALUES
# DO NOT COMMIT .env — IT CONTAINS SECRETS
#
# ============================================================================
# ⚠️  CRITICAL: REQUIRED VARIABLES (must be set in all environments)
# ============================================================================

# Database connection string
# Local SQLite:  DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"
# PostgreSQL:    DATABASE_URL="postgresql://user:password@localhost:5432/school"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# Server port (must match for unified deployment)
PORT=5173

# Node environment: "development" or "production"
NODE_ENV=development

# ⚠️  CRITICAL: Session/JWT secret (generate strong random value for production)
# Use: openssl rand -base64 32
# NEVER use the default "school_secret" in production
SESSION_SECRET="school_secret_change_me_in_production"

# ============================================================================
# 🌐 API CONFIGURATION (Unified Deployment)
# ============================================================================

# API base URL used by frontend client
# Local development:  http://localhost:5173/api
# Production:         https://your-school-domain.com/api
API_BASE_URL="http://localhost:5173/api"

# Base path for frontend routing (typically "/" for root deployment)
BASE_PATH="/"

# ============================================================================
# 📝 LOGGING CONFIGURATION
# ============================================================================

# Log level: "trace" | "debug" | "info" | "warn" | "error" | "fatal"
LOG_LEVEL="info"

# ============================================================================
# 🚀 DEPLOYMENT NOTES
# ============================================================================
#
# LOCAL DEVELOPMENT:
#   1. Copy this file to .env
#   2. Generate SESSION_SECRET: openssl rand -base64 32
#   3. Run: pnpm install && pnpm start
#   4. Access: http://localhost:5173
#
# PRODUCTION DEPLOYMENT:
#   1. Set DATABASE_URL to production PostgreSQL instance
#   2. Generate STRONG SESSION_SECRET (openssl rand -base64 32)
#   3. Set API_BASE_URL to production domain/subdomain
#   4. Set NODE_ENV="production"
#   5. Ensure PORT is accessible in your infrastructure
#   6. Run migrations: pnpm db:push
#   7. Start server: pnpm start
#
# DOCKER DEPLOYMENT:
#   Pass environment variables via:
#     docker run -e DATABASE_URL="..." -e SESSION_SECRET="..." ...
#
# ============================================================================
SESSION_SECRET="1/WkYOkFhs7azoij8I06NCFSF5C+KFy9dO96O/VO3MQ="
